# ============================================================
# Database Configuration
# ============================================================
DATABASE_URL=mysql+pymysql://user:password@localhost/usatelier_db
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=usatelier_db
MYSQL_USER=user
MYSQL_PASSWORD=password

# ============================================================
# Flask Configuration
# ============================================================
FLASK_ENV=production
SECRET_KEY=your-secret-key-change-this-in-production
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Strict

# ============================================================
# Delhivery Configuration (NEW)
# ============================================================
DELHIVERY_API_KEY=your_delhivery_api_key_here
DELHIVERY_FACILITY_CODE=your_facility_code_here

# Store Location Details (for Delhivery pickup)
STORE_PHONE=+91-XXXX-XXXX-XXXX
STORE_NAME=U.S Atelier
STORE_ADDRESS=Your Store Address
STORE_CITY=Your City
STORE_STATE=Your State
STORE_PINCODE=Your Pincode

# ============================================================
# Razorpay Configuration
# ============================================================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ============================================================
# Email Configuration
# ============================================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465
MAIL_USE_TLS=False
MAIL_USE_SSL=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@usatelier.com

# ============================================================
# Google OAuth Configuration
# ============================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration

# ============================================================
# Admin Configuration
# ============================================================
ADMIN_EMAIL=admin@usatelier.com
ADMIN_PASSWORD=your-secure-admin-password

# ============================================================
# Frontend Configuration
# ============================================================
NEXT_PUBLIC_API_BASE=http://localhost:5000
NEXT_PUBLIC_APP_NAME=U.S Atelier
NEXT_PUBLIC_MEDIA_BASE=http://localhost:5000/media

# ============================================================
# Logging Configuration
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================
# DEPRECATED: Borzo Configuration (Keep for backward compatibility)
# ============================================================
# BORZO_API_URL=https://api.borzo.ru/api/v2
# BORZO_API_TOKEN=your_borzo_api_token_here
